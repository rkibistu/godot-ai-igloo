# Runtime secrets for the autonomous agent container — copy to `.env` (gitignored)
# and fill in real values. NEVER baked into the image; injected via `docker run -e`.

# Bot GitHub account (justfortest1234) classic PAT, scopes: repo + workflow.
# Used for HTTPS push + `gh` PR/comment operations as the bot. Required.
BOT_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code subscription OAuth token, from `claude setup-token`.
# Not needed for the Phase 2 proof (no agent runs); required from Phase 4 on.
CLAUDE_CODE_OAUTH_TOKEN=

# Human reviewer (rkibistu) PAT — repo scope. OPTIONAL, used ONLY by the Phase 3 proof
# to author the row-2 inline review thread as the human (a thread the bot cannot create,
# since "last author != bot" is the fix trigger). If unset, the proof SKIPS row 2.
# Mirrors the real architecture: reviewer and bot are distinct identities/tokens.
REVIEWER_GH_TOKEN=

# ── Phase 5 review-setup (host-side; all OPTIONAL) ──────────────────────────────
# Path to a host Godot 4.6.x MONO binary. If unset, review_setup.sh extracts the zip at
# GODOT_ZIP once into .tools/godot/ and uses that.
GODOT_BIN=
# Source zip for the one-time extract (default: ~/Downloads/Godot_v4.6.3-stable_mono_linux_x86_64.zip).
GODOT_ZIP=
# Where review worktrees are created (default: a sibling dir "<repo>-review/", outside the repo).
REVIEW_WORKTREE_DIR=
# Your IDE executable — `igloo review` opens it on the worktree root alongside the Godot editor.
# A bare name on PATH works (e.g. IDE_BIN=code), or an absolute path. If unset, review_setup.sh
# auto-detects a VS Code CLI (code/codium/code-insiders). Pass `--no-ide` to skip launching it.
IDE_BIN=
