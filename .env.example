# Runtime secrets for the autonomous agent container — copy to `.env` (gitignored)
# and fill in real values. NEVER baked into the image; injected via `docker run -e`.

# Bot GitHub account (justfortest1234) classic PAT, scopes: repo + workflow.
# Used for HTTPS push + `gh` PR/comment operations as the bot. Required.
BOT_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code subscription OAuth token, from `claude setup-token`.
# Not needed for the Phase 2 proof (no agent runs); required from Phase 4 on.
CLAUDE_CODE_OAUTH_TOKEN=
